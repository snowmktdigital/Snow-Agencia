CONTACT_EMAIL_TO=contato@snowagencia.com
CONTACT_EMAIL_FROM="Snow Agência de Crescimento <contato@snowagencia.com>"

# SMTP da caixa de e-mail profissional, por exemplo Hostinger.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@snowagencia.com
SMTP_PASS=

# Opcional: fallback via Resend, caso você também configure o domínio no Resend.
RESEND_API_KEY=
